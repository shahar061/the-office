{
  "name": "the-office",
  "version": "0.1.1",
  "description": "Pixel-art agent visualization Electron app",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-maps": "tsx scripts/generate-maps.ts",
    "dev:mobile-renderer": "vite --config vite.config.mobile.ts",
    "build:mobile-renderer": "vite build --config vite.config.mobile.ts",
    "copy:webview": "tsx scripts/copy-webview-bundle.ts",
    "build:mobile-all": "npm run build:mobile-renderer && npm run copy:webview",
    "dev:jump": "tsx dev-jump/cli/dev-jump.ts",
    "dev:worker": "cd feedback-worker && npm run dev",
    "deploy:worker": "cd feedback-worker && npm run deploy",
    "dev:admin": "cd feedback-admin && npm run dev",
    "deploy:admin": "cd feedback-admin && npm run deploy",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "keywords": [],
  "author": "shahar061",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/shahar061/the-office.git"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "1.6",
    "commander": "^12.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^21.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "1.6"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.17.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.35.2",
    "ws": "^8.20.0",
    "zustand": "^5.0.11"
  }
}
